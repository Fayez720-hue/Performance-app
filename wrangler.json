{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "performance-app-v1",
  "main": ".worker-next/index.mjs",
  "compatibility_date": "2024-10-30",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".worker-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "NEXT_RUNTIME": "edge"
  }
}
